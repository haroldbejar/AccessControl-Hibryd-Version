# Copia este archivo como .env y completa los valores
# El archivo .env NUNCA debe subirse al repositorio (.gitignore ya lo excluye)

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=accesscontrol

# ── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres para HS256
JWT_KEY=
JWT_ISSUER=AccessControl.API
JWT_AUDIENCE=AccessControl.Client
JWT_EXPIRES_MINUTES=60
